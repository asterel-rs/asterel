  "components": {
    "schemas": {
      "ProblemDetails": {
        "type": "object",
        "required": ["type", "title", "status", "detail", "code"],
        "properties": {
          "type": { "type": "string" },
          "title": { "type": "string" },
          "status": { "type": "integer" },
          "detail": { "type": "string" },
          "code": { "type": "string" }
        }
      },
      "RuntimeStatus": {
        "type": "object",
        "required": ["status", "version", "model", "db", "gateway", "capabilities"],
        "properties": {
          "status": { "type": "string", "enum": ["ok", "degraded"] },
          "version": { "type": "string" },
          "model": { "type": "string" },
          "db": {
            "type": "object",
            "required": ["engine", "status"],
            "properties": {
              "engine": { "type": "string" },
              "status": { "type": "string" }
            }
          },
          "gateway": {
            "type": "object",
            "required": ["ws_connections", "max_ws_connections"],
            "properties": {
              "ws_connections": { "type": "number" },
              "max_ws_connections": { "type": "number" }
            }
          },
          "capabilities": {
            "type": "object",
            "required": [
              "companion",
              "governance",
              "memory_review",
              "channel_posture",
              "session_review",
              "a2a",
              "multi_tenant"
            ],
            "properties": {
              "companion": { "type": "boolean" },
              "governance": { "type": "boolean" },
              "memory_review": { "type": "boolean" },
              "channel_posture": { "type": "boolean" },
              "session_review": { "type": "boolean" },
              "a2a": { "type": "boolean" },
              "multi_tenant": { "type": "boolean" }
            }
          }
        }
      },
      "UsageResponse": {
        "type": "object",
        "required": [
          "total_input_tokens",
          "total_output_tokens",
          "total_tokens",
          "session_count",
          "message_count",
          "model"
        ],
        "properties": {
          "total_input_tokens": { "type": "number" },
          "total_output_tokens": { "type": "number" },
          "total_tokens": { "type": "number" },
          "session_count": { "type": "number" },
          "message_count": { "type": "number" },
          "model": { "type": "string" }
        }
      },
      "MoodResponse": {
        "type": "object",
        "required": ["label", "confidence", "description"],
        "properties": {
