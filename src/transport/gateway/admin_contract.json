          "400": {
            "description": "Approval request is invalid",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/ProblemDetails" } }
            }
          },
          "403": {
            "description": "Approval is outside the caller tenant scope",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/ProblemDetails" } }
            }
          },
          "404": {
