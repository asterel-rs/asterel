{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "main-capability",
  "description": "Default permissions for the Asterel main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:window:allow-set-title",
    "core:window:allow-minimize",
    "core:window:allow-close",
    "core:app:default",
    "core:tray:default",
    "core:event:default",
    "core:path:default",
    "opener:default",
    "store:default",
    "websocket:default",
    "notification:default",
    "process:default",
    "log:default",
    "os:default",
    "window-state:default",
    "deep-link:default"
  ]
}
