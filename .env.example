# Asterel — Environment Variable Reference
# Copy to .env and fill in values. All variables are optional unless noted.

# ── Provider / Model ────────────────────────────────────────────
# Required: LLM provider API key
ASTEREL_API_KEY=

# Provider: openrouter | openai | anthropic | ollama
ASTEREL_PROVIDER=openrouter

# Model override (provider-specific identifier)
# ASTEREL_MODEL=anthropic/claude-sonnet-4-20250514

# Sampling temperature (0.0–2.0)
# ASTEREL_TEMPERATURE=0.7

# ── Paths ───────────────────────────────────────────────────────
# Workspace directory override
# ASTEREL_WORKSPACE=~/.asterel/workspace

# ── Memory / scheduler persistence ───────────────────────────────
# PostgreSQL URL for durable memory and cron scheduler state
# ASTEREL_POSTGRES_URL=postgres://asterel@localhost/asterel

# ── Gateway ─────────────────────────────────────────────────────
# ASTEREL_GATEWAY_HOST=127.0.0.1
# ASTEREL_GATEWAY_PORT=3000
# Maximum request body size in bytes for gateway routes
# ASTEREL_GATEWAY_MAX_BODY_SIZE_BYTES=65536
# Explicit opt-in for non-local binds; keep false unless behind a trusted edge
# ASTEREL_GATEWAY_ALLOW_PUBLIC_BIND=false

# API keys for OpenAI-compatible /v1/chat/completions endpoint (comma-separated)
# ASTEREL_OPENAI_API_KEYS=

# ── Optional intent classifier ───────────────────────────────────
# ASTEREL_INTENT_CLASSIFIER_ENABLED=false
# ASTEREL_INTENT_CLASSIFIER_THRESHOLD=0.5
# ASTEREL_INTENT_CLASSIFIER_MODELS_DIR=~/.asterel/models

# ── Channels ────────────────────────────────────────────────────
# DISCORD_TOKEN=
# TELEGRAM_BOT_TOKEN=
# SLACK_BOT_TOKEN=
# SLACK_APP_TOKEN=
# MATRIX_HOMESERVER=
# MATRIX_USER=
# MATRIX_PASSWORD=
